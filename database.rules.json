{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name'])"
      }
    },

    "holdings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "shared": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('friends/' + $uid + '/' + auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "friends": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friend": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friend)",
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "invites": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('from').val() === auth.uid) || (data.exists() && data.child('from').val() === auth.uid))",
        ".validate": "newData.hasChildren(['from', 'exp'])"
      }
    }
  }
}
